APP_NAME=ai-photo-telegram-bot
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
TELEGRAM_MODE=polling
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com
TELEGRAM_WEBHOOK_SECRET=change_me_secret
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
LOG_LEVEL=INFO
MEDIA_DIR=./data/media
INPUT_DIR=./data/media/input
OUTPUT_DIR=./data/media/output
TEMP_DIR=./data/media/temp
REMOVE_BG_API_KEY=your_remove_bg_api_key
REMOVE_BG_API_URL=https://api.remove.bg/v1.0/removebg
REMOVE_BG_TIMEOUT_SECONDS=60
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_TIMEOUT_SECONDS=45
MAX_HISTORY_ITEMS=10
TEMPLATE_SEED_PATH=./app/prompt_templates/trend_templates.json

IMAGE_PROVIDER=multi
IMAGE_PROVIDER_CHAIN=replicate,fal
IMAGE_PROVIDER_PRIMARY_BY_MODE=avatar:replicate,poster:replicate,product:replicate,stickers:fal

REPLICATE_API_KEY=your_replicate_api_key
REPLICATE_MODEL_OWNER=black-forest-labs
REPLICATE_MODEL_NAME=flux-kontext-max
REPLICATE_TIMEOUT_SECONDS=240
REPLICATE_WAIT_SECONDS=120

FAL_API_KEY=your_fal_api_key
FAL_MODEL_ID=fal-ai/nano-banana-2/edit
FAL_TIMEOUT_SECONDS=240
FAL_POLL_INTERVAL_SECONDS=2

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_TIMEOUT_SECONDS=180
